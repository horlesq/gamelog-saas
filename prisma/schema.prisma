generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model User {
  id                  String    @id @default(cuid())
  email               String    @unique
  password            String?
  name                String?
  emailVerified       DateTime?
  googleId            String?   @unique
  steamId             String?   @unique
  isAdmin             Boolean   @default(false)
  plan                Plan      @default(FREE)
  polarSubscriptionId String?   @unique
  polarProductId      String?
  polarCustomerId     String?
  planUpdatedAt       DateTime?
  aiGenerationsCount  Int       @default(0)
  lastAiGenerationAt  DateTime?
  gameLogs            GameLog[]
  customFilters       CustomFilter[]
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@map("users")
}

enum Plan {
  FREE
  PRO
  ULTRA
}

model Game {
  id              String    @id @default(cuid())
  rawgId          Int       @unique
  name            String
  slug            String?
  backgroundImage String?
  released        String?
  metacritic      Int?
  genres          String?
  platforms       String?
  developers      String?
  gameLogs        GameLog[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("games")
}

model GameLog {
  id          String     @id @default(cuid())
  status      GameStatus @default(PLAN_TO_PLAY)
  rating      Int?
  hoursPlayed Float?
  platforms   String? // JSON array of strings
  notes       String?
  startedAt   DateTime?
  completedAt DateTime?

  gameId    String
  game      Game   @relation(fields: [gameId], references: [id], onDelete: Cascade)
  userId    String
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([gameId, userId])
  @@map("game_logs")
}

enum GameStatus {
  PLAN_TO_PLAY
  PLAYING
  COMPLETED
}

model CustomFilter {
  id         String   @id @default(cuid())
  name       String
  icon       String   @default("filter")
  color      String   @default("purple")
  conditions String   // JSON: { status?, genres?, platforms?, ratingMin?, ratingMax?, hoursMin?, hoursMax? }
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("custom_filters")
}

model VerificationToken {
  id         String   @id @default(cuid())
  identifier String
  token      String   @unique
  expires    DateTime
  createdAt  DateTime @default(now())

  @@unique([identifier, token])
  @@map("verification_tokens")
}