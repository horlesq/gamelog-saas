# Database Connection
# Neon PostgreSQL connection string (https://neon.tech)
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# Security
# Secret key for JWT token generation. Change this to a random string in production!
JWT_SECRET="changeme"

# External APIs
# RAWG API Key for fetching game data (https://rawg.io/apidocs)
RAWG_API_KEY=""

# Email Service (https://resend.com)
RESEND_API_KEY=""

# Google OAuth (https://console.cloud.google.com)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Steam OpenID (https://steamcommunity.com/dev/apikey)
STEAM_WEB_API_KEY=""

# App Configuration
NEXT_PUBLIC_APP_URL="http://localhost:3000"
